{
  "fromVersion": "1.7.10",
  "toVersion": "1.12.2",
  "loader": "forge",
  "notes": "Bridges the 1.7.10 → 1.12.2 gap: registry system overhaul (GameRegistry static methods → ForgeRegistries + RegistryEvents), metadata-bearing constructor patterns, and block/item registration refactoring.",
  "rules": [
    {
      "id": "gameregistry-registerblock-to-registerevent",
      "kind": "METHOD_CALL_ARGS_TO_OBJECT",
      "receiverTypes": ["cpw.mods.fml.common.registry.GameRegistry", "net.minecraftforge.fml.common.registry.GameRegistry"],
      "methodName": "registerBlock",
      "matchSignature": ["Block", "String"],
      "wrapperConstructor": null,
      "direction": "forward",
      "inverse": "registerevent-to-gameregistry-registerblock",
      "reason": "GameRegistry.registerBlock(block, name) was removed in 1.12. Blocks must now use Block.setRegistryName(name) + ForgeRegistries.BLOCKS.register() inside a RegistryEvent handler.",
      "replacement": {
        "pattern": "GameRegistry.registerBlock({0}, {1})",
        "template": "{0}.setRegistryName({1})"
      }
    },
    {
      "id": "gameregistry-registeritem-to-registerevent",
      "kind": "METHOD_CALL_ARGS_TO_OBJECT",
      "receiverTypes": ["cpw.mods.fml.common.registry.GameRegistry", "net.minecraftforge.fml.common.registry.GameRegistry"],
      "methodName": "registerItem",
      "matchSignature": ["Item", "String"],
      "wrapperConstructor": null,
      "direction": "forward",
      "inverse": null,
      "reason": "GameRegistry.registerItem(item, name) was removed in 1.12. Items must now use Item.setRegistryName(name) + ForgeRegistries.ITEMS.register().",
      "replacement": {
        "pattern": "GameRegistry.registerItem({0}, {1})",
        "template": "{0}.setRegistryName({1})"
      }
    },
    {
      "id": "block-getidfromblock-to-getstateid",
      "kind": "METHOD_CALL_ARGS_TO_OBJECT",
      "receiverTypes": ["net.minecraft.block.Block"],
      "methodName": "getIdFromBlock",
      "matchSignature": ["Block"],
      "wrapperConstructor": null,
      "direction": "forward",
      "inverse": null,
      "reason": "Block.getIdFromBlock(block) was replaced by Block.getStateId(block.getDefaultState()) in 1.12 as part of the move away from raw numeric IDs.",
      "replacement": {
        "pattern": "Block.getIdFromBlock({0})",
        "template": "Block.getStateId({0}.getDefaultState())"
      }
    },
    {
      "id": "itemstack-constructor-strip-metadata",
      "kind": "CONSTRUCTOR_ARG_STRIP",
      "receiverTypes": ["net.minecraft.item.ItemStack"],
      "methodName": "<init>",
      "matchSignature": ["Item", "int", "int"],
      "stripPositions": [2],
      "direction": "forward",
      "inverse": "itemstack-constructor-inject-metadata",
      "reason": "In 1.7.10, ItemStack(item, count, metadata) was common. In 1.12.2+, metadata is still present but should migrate toward NBT/capability patterns. This rule flags the usage."
    },
    {
      "id": "fml-package-migration",
      "kind": "IMPORT_REWRITE",
      "direction": "forward",
      "reason": "FML package was relocated from cpw.mods.fml to net.minecraftforge.fml between 1.7 and 1.8+.",
      "importRewrites": {
        "cpw.mods.fml.common": "net.minecraftforge.fml.common",
        "cpw.mods.fml.relauncher": "net.minecraftforge.fml.relauncher",
        "cpw.mods.fml.client": "net.minecraftforge.fml.client"
      }
    },
    {
      "id": "creativetabs-package-migration",
      "kind": "IMPORT_REWRITE",
      "direction": "forward",
      "reason": "CreativeTabs was relocated.",
      "importRewrites": {
        "net.minecraft.creativetab.CreativeTabs": "net.minecraft.item.ItemGroup"
      }
    }
  ]
}
