{
  "fromVersion": "1.12.2",
  "toVersion": "1.7.10",
  "loader": "forge",
  "notes": "Reverse rules for downporting 1.12.2 mods to 1.7.10. Restores legacy GameRegistry calls, re-introduces metadata parameters, and reverses FML package relocation.",
  "rules": [
    {
      "id": "registerevent-to-gameregistry-registerblock",
      "kind": "METHOD_CALL_OBJECT_TO_ARGS",
      "receiverTypes": ["net.minecraft.block.Block"],
      "methodName": "setRegistryName",
      "matchSignature": ["String"],
      "unwrapAccessors": [],
      "direction": "backward",
      "inverse": "gameregistry-registerblock-to-registerevent",
      "reason": "Downporting to 1.7.10: Block.setRegistryName(name) does not exist. Must restore GameRegistry.registerBlock(block, name).",
      "replacement": {
        "pattern": "{receiver}.setRegistryName({0})",
        "template": "GameRegistry.registerBlock({receiver}, {0})"
      }
    },
    {
      "id": "itemstack-constructor-inject-metadata",
      "kind": "CONSTRUCTOR_ARG_INJECT",
      "receiverTypes": ["net.minecraft.item.ItemStack"],
      "methodName": "<init>",
      "matchSignature": ["Item", "int"],
      "injectPosition": 2,
      "injectValue": "0",
      "direction": "backward",
      "inverse": "itemstack-constructor-strip-metadata",
      "reason": "Downporting to 1.7.10: ItemStack(item, count) needs metadata parameter. Injecting default metadata=0."
    },
    {
      "id": "fml-package-migration-reverse",
      "kind": "IMPORT_REWRITE",
      "direction": "backward",
      "reason": "Reverse FML package relocation for 1.7.10 compatibility.",
      "importRewrites": {
        "net.minecraftforge.fml.common": "cpw.mods.fml.common",
        "net.minecraftforge.fml.relauncher": "cpw.mods.fml.relauncher",
        "net.minecraftforge.fml.client": "cpw.mods.fml.client"
      }
    },
    {
      "id": "world-getblockstate-to-getblock",
      "kind": "METHOD_CALL_OBJECT_TO_ARGS",
      "receiverTypes": ["net.minecraft.world.World", "net.minecraft.world.IBlockAccess"],
      "methodName": "getBlockState",
      "matchSignature": ["net.minecraft.util.math.BlockPos"],
      "unwrapAccessors": ["getX", "getY", "getZ"],
      "direction": "backward",
      "inverse": "world-getblockstate-flatten",
      "reason": "Downporting to 1.7.10: World#getBlockState(BlockPos) does not exist. Expand to World#getBlock(x, y, z).",
      "replacement": {
        "methodName": "getBlock"
      }
    }
  ]
}
